{
  "provider": { "name": "openrouter", "apiKeyEnv": "OPENROUTER_API_KEY" },
  "inheritPi": false,
  "extensions": { "enabled": false },
  "repoContext": { "enabled": true },
  "deliverable": {
    "pr": false,
    "localPr": true,
    "baseBranch": "main"
  },
  "orchestrator": {
    "model": "openrouter/xiaomi/mimo-v2.5-pro",
    "workflow": ["planner", "dev"],
    "maxIterations": 6,
    "loops": {}
  },
  "mergeGate": {
    "autoMerge": true,
    "maxDiffLines": 300,
    "maxFiles": 10
  }
}
